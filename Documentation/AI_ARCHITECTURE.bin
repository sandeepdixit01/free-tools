PG_static:R:[SEOHead]|O:[AdSlot]|SEO:[meta,h1]
C_SEOHead:P:[title,description,keywords,canonical]|U:*|REQ:1
C_Hero:P:[config,quickAccessTools]|U:[home]|H1:config.hero[L].title
C_ToolHero:P:[title,subtitle,benefits,ctaText,privacyNotice]|U:[tool,category]|H1:title
C_ToolLayout:P:[heroComponent,featuresComponent,howToComponent,seoComponent,faqComponent,adSlots,children]|U:[tool]|WRAP:1
C_FileUpload:P:[accept,maxSize,maxFiles,files,onFileSelect,onDrop,onClear]|U:[tool]|DEP:useFileUpload
C_ControlPanel:P:[title,children]|U:[tool]|CUSTOM:1
C_PreviewPane:P:[items,showComparison,comparisonLabels]|U:[tool]|DEP:preparePreviewData
C_DownloadButton:P:[onClick,text,variant,size]|U:[tool]
C_ToolGrid:P:[tools,showViewAll]|U:[home,category]|SRC:getActiveTools()
C_CategoryGrid:P:[categories]|U:[home]|SRC:homeConfig.categories
C_FAQ:P:[title,items]|U:*|SCHEMA:1
C_SEOContent:P:[title,intro,sections]|U:*|OPT:1
C_AdSlot:P:[position,excludeCategory]|U:*|POS:[TOP_BANNER,BELOW_HERO,MID_CONTENT,BOTTOM_BANNER]
SEO:HANDLER:SEOHead|SCHEMA_home:[Organization,WebSite,FAQPage]|SCHEMA_tool:[WebApplication,HowTo,FAQPage]|SCHEMA_category:[CollectionPage,FAQPage]|FAQ:*|LINK_home→category:CategoryGrid|LINK_home→tool:ToolGrid|LINK_category→tool:ToolGrid
DATA:CFG:src/configs/|TOOLS:src/data/tools.js|FLOW:cfg[L]→props|STATIC:cfg|DYNAMIC:getActiveTools()|getToolsByCategory()
NAMING:ROUTE_home:/|ROUTE_tool:/tools/:toolId|ROUTE_category:/tools/:categoryId|ROUTE_static:/:page|COMP:PascalCase|CFG:camelCase.config.js|PROPS:camelCase
REUSE:MUST:[SEOHead,ToolHero,FAQ,SEOContent,AdSlot,ToolGrid]|NO_DUP:[h1,meta,faq_schema]|CFG_DRIVEN:[text,seo,ui]
TPL_home:[SEOHead→Hero→AdSlot(BELOW_HERO)→ToolGrid→CategoryGrid→AdSlot(MID_CONTENT)→WhyUseOurTools→SEOContent→FAQ→AdSlot(BOTTOM_BANNER)]
TPL_tool:[SEOHead→ToolLayout[ToolHero→AdSlot(TOP)→FileUpload→ControlPanel?→PreviewPane→DownloadButton→AdSlot(BELOW_HERO)→ToolFeatures?→ToolHowTo?→AdSlot(MID)→SEOContent?→FAQ→AdSlot(BOTTOM)]]
TPL_category:[SEOHead→ToolHero→AdSlot(BELOW_HERO)→ToolGrid→AdSlot(MID_CONTENT)→SEOContent?→FAQ→AdSlot(BOTTOM_BANNER)]
