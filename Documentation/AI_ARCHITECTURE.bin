APP:React+Vite|router:react-router-dom|pg:[home,tool,category,static]
PG_home:R:[SEOHead,Hero,ToolGrid,CategoryGrid,WhyUseOurTools,FAQ]|O:[SEOContent,AdSlot]|SEO:[meta,h1,faq_schema]
PG_tool:R:[SEOHead,ToolLayout,ToolHero,FileUpload,PreviewPane,DownloadButton,FAQ]|O:[ControlPanel,ToolFeatures,ToolHowTo,SEOContent,AdSlot]|SEO:[meta,h1,faq_schema,howto_schema]
