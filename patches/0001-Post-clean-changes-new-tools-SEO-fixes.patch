+{
+  "@context": "https://schema.org",
+  "@type": "HowTo",
+  "name": "How to use Word Counter",
+  "description": "Step-by-step guide to use Word Counter",
+  "step": [
+    {
+      "@type": "HowToStep",
+      "position": 1,
+      "name": "Enter or Paste Your Text",
+      "text": "Type directly into the text area or paste your content...",
+      "image": "📝"
