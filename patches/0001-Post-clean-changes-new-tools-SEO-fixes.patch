+  display: flex;
+  align-items: center;
+  gap: 0.25rem;
+}
+
+.stat-separator {
+  color: #6c757d;
+  margin: 0 0.25rem;
+}
+
+/* Responsive Design */
+@media (max-width: 768px) {
+  .json-to-csv-controls {
+    padding: 0.75rem;
+  }
+
+  .conversion-options {
+    flex-direction: column;
+    align-items: stretch;
+    gap: 1rem;
+  }
+
+  .option-group {
+    justify-content: space-between;
+  }
+
+  .section-header {
+    flex-direction: column;
+    align-items: stretch;
+    gap: 0.5rem;
+  }
+
+  .output-actions {
+    justify-content: stretch;
+  }
+
+  .copy-button,
+  .download-button {
+    flex: 1;
+    justify-content: center;
+  }
+
+  .action-buttons {
+    flex-direction: column;
+  }
+
+  .convert-button,
+  .clear-button {
+    min-width: auto;
+    width: 100%;
+  }
+
+  .json-input,
+  .csv-output {
+    font-size: 0.85rem;
+    padding: 0.75rem;
+  }
+
+  .conversion-stats {
+    flex-wrap: wrap;
+    justify-content: center;
+  }
+}
+
+@media (max-width: 480px) {
+  .json-to-csv-controls {
+    padding: 0.5rem;
+  }
+
+  .conversion-options {
+    padding: 0.75rem;
+  }
+
+  .json-input,
+  .csv-output {
+    rows: 8;
+    font-size: 0.8rem;
+  }
+
+  .paste-button,
+  .copy-button,
+  .download-button {
+    font-size: 0.8rem;
+    padding: 0.4rem 0.8rem;
+  }
+
+  .primary-button,
+  .secondary-button {
+    font-size: 0.9rem;
+    padding: 0.6rem 1.2rem;
+  }
+}
+
+/* Dark mode support */
+@media (prefers-color-scheme: dark) {
+  .conversion-options {
+    background: #343a40;
+  }
+
+  .option-group label,
+  .checkbox-label span {
+    color: #e9ecef;
+  }
+
+  .delimiter-select {
+    background: #495057;
+    border-color: #6c757d;
+    color: #e9ecef;
+  }
+
+  .json-input,
+  .csv-output {
+    background: #495057;
+    border-color: #6c757d;
+    color: #e9ecef;
+  }
+
+  .csv-output {
+    background: #343a40;
+  }
+
+  .section-header label {
+    color: #e9ecef;
+  }
+}
+
+/* Focus indicators for accessibility */
+.convert-button:focus,
+.clear-button:focus,
+.copy-button:focus,
+.download-button:focus,
+.paste-button:focus {
+  outline: 2px solid #007bff;
+  outline-offset: 2px;
+}
+
+/* Loading state */
+.convert-button:disabled {
+  position: relative;
+}
+
+.convert-button:disabled::after {
+  content: '';
+  position: absolute;
+  width: 16px;
+  height: 16px;
+  margin: auto;
+  border: 2px solid transparent;
+  border-top-color: #ffffff;
+  border-radius: 50%;
+  animation: spin 1s linear infinite;
+}
+
+@keyframes spin {
+  0% { transform: rotate(0deg); }
+  100% { transform: rotate(360deg); }
+}
+
