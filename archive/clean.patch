+.contact-section {
+  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
+  color: white;
+  text-align: center;
+}
+
+.contact-section .section-title {
+  color: white;
+}
+
+.contact-description {
+  font-size: 1.125rem;
+  margin: 0 0 2rem 0;
+  opacity: 0.95;
+}
+
+.contact-info {
+  max-width: 600px;
+  margin: 0 auto;
+}
+
+.contact-email {
+  font-size: 1.125rem;
+  margin: 0 0 1rem 0;
+}
+
+.contact-email a {
+  color: white;
+  text-decoration: underline;
+  font-weight: 600;
+}
+
+.contact-email a:hover {
+  opacity: 0.8;
+}
+
+.contact-location {
+  font-size: 1.125rem;
+  margin: 0;
+  opacity: 0.95;
+}
+
+/* Responsive */
+@media (max-width: 768px) {
+  .about-hero {
+    padding: 3rem 1rem 2rem;
+  }
+
+  .about-h1 {
+    font-size: 2rem;
+  }
+
+  .about-subtitle {
+    font-size: 1.125rem;
+  }
+
+  .about-section {
+    padding: 3rem 1rem;
+  }
+
+  .section-title {
+    font-size: 1.75rem;
+  }
+
+  .section-subtitle {
+    font-size: 1rem;
+  }
+
+  .secure-grid,
+  .features-grid,
+  .tools-categories {
+    grid-template-columns: 1fr;
+    gap: 1.5rem;
+  }
+
+  .about-intro,
+  .mission-content {
+    font-size: 1rem;
+  }
+}
+
+@media (max-width: 480px) {
+  .about-h1 {
+    font-size: 1.75rem;
+  }
+
+  .about-subtitle {
+    font-size: 1rem;
+  }
+
+  .section-title {
+    font-size: 1.5rem;
+  }
+
+  .secure-icon {
+    font-size: 2.5rem;
+  }
+}
